generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ──────────────────────────────────────────
// 랭킹 수집 세션
// "이 100명은 같은 시점에 수집됐다"를 보장하는 단위
// ──────────────────────────────────────────
model RankingCollection {
  id           BigInt   @id @default(autoincrement())
  gameId       String   @default("aion2") @map("game_id") @db.VarChar(50)
  server       String   @default("KR") @db.VarChar(20)
  rankingType  String   @map("ranking_type") @db.VarChar(50)   // 'total', 'pvp', 'siege'
  contentsType String?  @map("contents_type") @db.VarChar(50)  // 'arena', 'openworld' 등
  totalCount   Int?     @map("total_count")
  collectedAt  DateTime @default(now()) @map("collected_at") @db.Timestamptz()

  // 관계: 이 수집에 속한 랭킹 스냅샷들
  snapshots          RankingSnapshot[]
  characterSnapshots CharacterSnapshot[]

  @@index([collectedAt(sort: Desc)], name: "idx_collection_collected_at")
  @@map("ranking_collections")
}

// ──────────────────────────────────────────
// 랭킹 스냅샷 (수집 시점의 각 캐릭터 순위)
// 핵심 테이블. 매 수집마다 100행씩 쌓임
// ──────────────────────────────────────────
model RankingSnapshot {
  id            BigInt   @id @default(autoincrement())
  collectionId  BigInt   @map("collection_id")
  rank          Int
  characterName String   @map("character_name") @db.VarChar(100)
  className     String   @map("class_name") @db.VarChar(50)
  level         Int?
  guildName     String?  @map("guild_name") @db.VarChar(100)
  score         BigInt?
  rawData       Json?    @map("raw_data") @db.JsonB  // API 원본 전체 보존
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz()

  // 관계: 어떤 수집 세션에 속하는지
  collection RankingCollection @relation(fields: [collectionId], references: [id])

  @@index([collectionId, className], name: "idx_snapshot_collection_class")
  @@index([characterName], name: "idx_snapshot_character_name")
  @@map("ranking_snapshots")
}

// ──────────────────────────────────────────
// 캐릭터 상세 스냅샷 (장비, 스탯, 스킬)
// Phase 1에서는 비워두고, API에서 상세 정보를 줄 때 채움
// ──────────────────────────────────────────
model CharacterSnapshot {
  id            BigInt   @id @default(autoincrement())
  collectionId  BigInt?  @map("collection_id")
  characterName String   @map("character_name") @db.VarChar(100)
  className     String   @map("class_name") @db.VarChar(50)
  level         Int?
  equipment     Json?    @db.JsonB  // 장비 슬롯별 아이템 정보
  stats         Json?    @db.JsonB  // 주요 스탯
  skills        Json?    @db.JsonB  // 스킬 세팅
  rawData       Json?    @map("raw_data") @db.JsonB
  snapshotAt    DateTime @default(now()) @map("snapshot_at") @db.Timestamptz()

  collection RankingCollection? @relation(fields: [collectionId], references: [id])

  @@index([characterName, snapshotAt(sort: Desc)], name: "idx_char_snapshot_name_time")
  @@map("character_snapshots")
}
